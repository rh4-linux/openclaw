# Copy to .env and fill in values

# Gateway auth token (generated during onboarding)
OPENCLAW_GATEWAY_TOKEN=

# Ports (defaults: 18789 UI, 18790 bridge)
# OPENCLAW_GATEWAY_PORT=18789
# OPENCLAW_BRIDGE_PORT=18790

# Timezone
# OPENCLAW_TZ=Europe/Kyiv

# Model provider API keys (set the one you use)
# GEMINI_API_KEY=
# GROQ_API_KEY=
# CLAUDE_AI_SESSION_KEY=
