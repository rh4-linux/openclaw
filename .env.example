# Copy to .env and fill in values

# Gateway auth token (generated during onboarding, or set manually)
OPENCLAW_GATEWAY_TOKEN=

# Host paths for config and workspace (defaults to ~/.openclaw and ~/openclaw/workspace)
# OPENCLAW_CONFIG_DIR=~/.openclaw
# OPENCLAW_WORKSPACE_DIR=~/openclaw/workspace

# Ports (defaults: 18789 UI, 18790 bridge)
# OPENCLAW_GATEWAY_PORT=18789
# OPENCLAW_BRIDGE_PORT=18790

# Timezone
# OPENCLAW_TZ=Europe/Kyiv

# Claude session key (if using Claude via web auth)
# CLAUDE_AI_SESSION_KEY=

# Groq
# GROQ_API_KEY=
